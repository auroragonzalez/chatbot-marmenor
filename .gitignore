# === Entorno virtual ===
venv/
ven/
.venv/
env/

# === Caché y compilados de Python ===
__pycache__/
*.py[cod]
*$py.class

# === Configuración y secretos ===
# La app se configura por variables de entorno (MODELO_LLM, HOST, PORT, RUTA_CSV...).
# Nunca subir archivos con credenciales o configuración local.
.env
.env.*
*.env

# === Datos ===
# Se versionan CSV pequeños, PDFs y los CSV grandes COMPRIMIDOS (.csv.gz).
# Los CSV crudos de ~500 MB NO se suben: superan el límite de 100 MB de GitHub
# (DuckDB lee el .csv.gz de forma nativa, así que el .gz basta para desplegar).
datos/datos_procesados/SAIH_Piezometros_unificados_limpios.csv
datos/datos_procesados/SAIH_ramblas_unificadas_limpias.csv

# NOTA: chroma_db/ SÍ se versiona para que el servidor arranque sin reingestar.

# === Logs ===
*.log
logs/

